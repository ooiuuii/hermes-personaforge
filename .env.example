# Copy to .env only if you need local credentials for experiments.
# The demo and proof pack run without production secrets.

# Optional model provider variables for custom Hermes experiments.
# The deterministic demo and proof pack do not require these.
NOUS_API_KEY=
NOUS_BASE_URL=https://inference-api.nousresearch.com/v1
NOUS_MODEL=nvidia/nemotron-3-ultra-550b-a55b
HERMES_GATEWAY_BASE_URL=http://127.0.0.1:8642/v1
HERMES_GATEWAY_MODEL=hermes-agent
HERMES_GATEWAY_API_KEY=

# Optional store/payment runtime variables for private local experiments.
# Never commit live keys, app private keys, merchant private keys, or customer PII.
NOPCOMMERCE_BASE_URL=
ALIPAY_APP_ID=
ALIPAY_SELLER_ID=

# Optional persona runtime variables for private local experiments.
# Do not commit third-party character packs, voice models, checkpoints, cookies, or local runtime paths.
SHINSEKAI_RUNTIME_URL=http://127.0.0.1:7860
PERSONA_PACK_DIR=
PERSONA_LICENSE_SECRET=

# Local app port.
APP_PORT=5173
